{
  "feishu": {
    "appId": "cli_your_feishu_app_id",
    "appSecret": "your_feishu_app_secret"
  },
  "restrictUsers": false,
  "restrictChatIds": false,
  "allowedUsers": [
    "ou_allowed_user_open_id"
  ],
  "allowedChatIds": [
    "oc_allowed_chat_id"
  ],
  "projects": [
    {
      "id": "code-bot",
      "name": "Code Bot",
      "path": "/absolute/path/to/your/project",
      "codexArgs": [
        "--ask-for-approval",
        "on-request"
      ]
    }
  ],
  "output": {
    "directMaxChars": 1800,
    "chunkSize": 1500,
    "terminalSnapshot": {
      "cols": 120,
      "rows": 40,
      "scrollback": 200,
      "replayMaxBytes": 262144,
      "cardMaxRows": 40,
      "cardMaxLineChars": 160,
      "maxStyledSegmentsPerLine": 8
    }
  },
  "codex": {
    "command": "codex",
    "defaultArgs": []
  },
  "ui": {
    "verbosity": "normal",
    "currentRenderMode": "markdown",
    "timeZone": "Asia/Shanghai"
  },
  "upgrade": {
    "enabled": false,
    "adminUsers": [],
    "pm2ProcessName": "code-bot",
    "remote": "origin",
    "branch": "main"
  },
  "logLevel": "info"
}
